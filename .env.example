# ── Scarab SEO content layer (build-time only) ───────────────────────────
# When CONTENT_API_BASE_URL and CONTENT_API_READ_TOKEN are both set, the build
# fetches published SEO/GEO content from the Scarab content OS and statically
# generates the /<routeGroup>/<slug> pages and their hubs. When unset, the
# content layer is disabled and the site builds without those pages.
#
# These are read ONLY during `next build`. The token is secret — never expose it
# with a NEXT_PUBLIC_ prefix or to the client.
CONTENT_API_BASE_URL=https://your-scarab-host
CONTENT_API_READ_TOKEN=your-read-token
# This storefront's product key in Scarab (defaults to "ayoo" if omitted).
CONTENT_API_PRODUCT_KEY=ayoo

# ── Canonical site URL ───────────────────────────────────────────────────
# Base used for canonicals and sitemap entries. Defaults to https://ayoo.dev.
NEXT_PUBLIC_SITE_URL=https://ayoo.dev

# ── Existing content source (unchanged) ──────────────────────────────────
# CONTENT_SOURCE=mdx
